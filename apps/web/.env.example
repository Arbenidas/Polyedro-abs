NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Supabase Auth (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# ElevenLabs guide agent
NEXT_PUBLIC_ELEVENLABS_GUIDE_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_GUIDE_DEMO_MODE=true
NEXT_PUBLIC_ELEVENLABS_GUIDE_ENABLE_TTS_OVERRIDES=false
NEXT_PUBLIC_ELEVENLABS_GUIDE_TTS_SPEED=1.08
NEXT_PUBLIC_ELEVENLABS_GUIDE_SCROLL_MS=1150
NEXT_PUBLIC_ELEVENLABS_GUIDE_SECTION_DWELL_MS=300
NEXT_PUBLIC_ELEVENLABS_GUIDE_SECTION_GAP_MS=0
NEXT_PUBLIC_ELEVENLABS_GUIDE_HIGHLIGHT_DWELL_MS=750
