# Origen(es) permitidos por CORS. Una URL, o varias separadas por comas
# (p. ej. "https://polyedro-abs.netlify.app,https://polyedro-ads.netlify.app").
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Supabase Auth (Project Settings → API); anon key o publishable key (sb_publishable_…)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
# Brand Agent (opcional; sin key el brand kit usa contenido template)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
