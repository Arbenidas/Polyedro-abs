{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@Polyedro-abs/env": "workspace:*",
    "@ai-sdk/openai": "^4.0.7",
    "@hono/node-server": "^1.14.4",
    "@supabase/supabase-js": "^2.110.0",
    "ai": "^7.0.15",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.2",
    "node-cron": "^4.5.0",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Polyedro-abs/config": "workspace:*",
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^22.13.14",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  }
}
